# Copy this to .env and fill in your values
# NEVER commit .env to git

# Required — Personize
PERSONIZE_SECRET_KEY=sk_...

# Required — Trigger.dev (from https://cloud.trigger.dev)
TRIGGER_PROJECT_ID=proj_...
TRIGGER_SECRET_KEY=tr_dev_...

# ─── Email Accounts (IMAP/SMTP — Default) ─────────────────────
# Email accounts are managed via the dashboard (Settings → Email Accounts).
# No env vars needed — just add accounts in the UI.
#
# Supported: Gmail, Outlook, ZapMail, Instantly, Zoho, Fastmail, any IMAP/SMTP.
# For Gmail/Outlook: use App Passwords (enable 2FA first).
# For ZapMail/Instantly: export credentials from their dashboard.
#
# Optional: Encryption key for IMAP credentials at rest (defaults to PERSONIZE_SECRET_KEY)
# IMAP_ENCRYPTION_KEY=your-secret-encryption-key
# IMAP_POLL_INTERVAL_MINUTES=3

# ─── Optional: Personize Webhook ──────────────────────────────
# Set a secret to verify incoming Personize webhooks (new contact/company events).
# PERSONIZE_WEBHOOK_SECRET=your-webhook-secret

# Optional — HubSpot (not required if using CSV, Zapier, or API import)
# HUBSPOT_ACCESS_TOKEN=pat-...

# Optional — Gmail API (alternative to IMAP/SMTP for Google Workspace users)
# GMAIL_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=GOCSPX-xxxxx
# GMAIL_REFRESH_TOKEN=1//xxxxx
# SENDER_EMAIL=you@yourcompany.com
# SENDER_NAME=Your Name

# Optional — Slack (for alerts and reports)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── AI Provider (BYOK — Bring Your Own Key) ─────────────────
# All optional. If omitted, Personize handles model selection automatically via tier.
# Tier: 'basic' | 'pro' | 'ultra' (default: 'pro')
# AI_TIER=pro
# Provider: 'openai' | 'anthropic' | 'google' | 'xai' | 'deepseek' | 'openrouter'
# AI_PROVIDER=
# Model: e.g. 'gpt-4o', 'claude-sonnet-4-20250514', 'gemini-2.0-flash', etc.
# AI_MODEL=
# API key for BYOK billing (required if provider/model are set)
# AI_API_KEY=

# ─── Agent Mode ─────────────────────────────────────────────────
# Controls WHO you contact, WHY, and HOW you talk to them.
# The pipeline stays the same — modes reconfigure governance, cadences, and signals.
#
# Sales & GTM:     outbound-sdr (default), abm, cold-deals, partner-recruitment, event-followup
# Ecommerce:       ecommerce-winback, post-purchase, cart-abandonment
# Membership:      member-renewal, member-onboarding
# Recruiting:      talent-sourcing, employee-onboarding
# Education:       student-enrollment, alumni-engagement
# Real Estate:     real-estate-nurture
# Agency:          agency-outreach
# Nonprofit:       donor-engagement, volunteer-recruitment
AGENT_MODE=outbound-sdr

# ─── Budget Tier ────────────────────────────────────────────────
# How aggressively (and expensively) the agent monitors accounts.
# conservative = quarterly scoring, no research (cheapest)
# balanced     = monthly scoring, research for hot accounts (recommended)
# aggressive   = weekly scoring, research for hot + warm (most expensive)
BUDGET_TIER=balanced

# Safety: set to exactly "false" (lowercase) to send real emails. Any other value = dry run.
DRY_RUN=true

# Optional — HubSpot task owner (for createHubSpotTask)
# HUBSPOT_OWNER_ID=12345678

# ─── Apollo.io (Enrichment + Contact Discovery) ────────────────
# Get your key from: Apollo.io → Settings → Integrations → API Keys
APOLLO_API_KEY=

# ─── Tavily (Web Research) ────────────────────────────────────────
# Get your key from: https://tavily.com → Dashboard → API Keys
# Cost: ~$0.01 per search. Used for company news, funding, hiring signals.
TAVILY_API_KEY=

# ─── HubSpot Filtering ─────────────────────────────────────────
# Internal name of the custom property that tags leads for Personize.
# Find in: HubSpot → Settings → Properties → search "Personize" → Internal name
# Leave empty to sync ALL contacts/companies (no filter).
HUBSPOT_PERSONIZE_LEAD_PROPERTY=personize___lead

# ─── CRM Source ──────────────────────────────────────────────────
# Which data sources to sync: 'hubspot', 'salesforce', 'csv', 'clay', or 'all'.
# CRM_SOURCE=hubspot

# ─── Salesforce (if using Salesforce) ─────────────────────────────
# SF_LOGIN_URL=https://login.salesforce.com
# SF_USERNAME=user@company.com
# SF_PASSWORD=yourpassword
# SF_TOKEN=yoursecuritytoken
# Optional: SOQL WHERE clause to filter contacts/accounts
# SF_CONTACT_FILTER=Lead_Source__c = 'Personize'
# SF_ACCOUNT_FILTER=

# ─── Clay.com (Optional — OFF by default) ──────────────────────────
# Clay is a data enrichment + workflow platform with 100+ providers.
# Use it for waterfall enrichment, AI lead research, and combining multiple
# data sources without writing code.
#
# Two modes:
#   webhook (default) — Clay POSTs enriched rows to your Trigger.dev webhook URL.
#                       Deploy, copy the "clay-webhook" URL from Trigger.dev dashboard,
#                       paste it into your Clay table's HTTP POST action.
#   pull             — Your system pulls rows from Clay on the crm-sync schedule.
#                       Requires CLAY_API_KEY and CLAY_TABLE_URL.
#
# CLAY_ENABLED=true
# CLAY_MODE=webhook
#
# Pull mode only:
# CLAY_API_KEY=
# CLAY_TABLE_URL=https://api.clay.com/v1/tables/YOUR_TABLE_ID/rows
#
# Webhook security (optional but recommended — set same value in Clay's HTTP headers):
# CLAY_WEBHOOK_SECRET=your-secret-here
#
# Which Personize collection to import into: 'contacts' or 'companies'
# CLAY_TARGET_COLLECTION=contacts
#
# Custom field mapping (JSON) — maps Clay column names to Personize properties.
# If omitted, auto-detects common column names (email, first_name, company, etc.).
# CLAY_FIELD_MAPPING={"Email Address":"email","Full Name":"first_name","Company":"company_name"}
#
# Pull mode limits:
# CLAY_PULL_BATCH_SIZE=100
# CLAY_MAX_ROWS_PER_SYNC=1000

# ─── LinkedIn Outreach (Optional — OFF by default) ───────────────
# Set to "true" to enable LinkedIn as an outreach channel.
# LinkedIn actions go out AFTER Email 1 per the multi-channel playbook.
# LINKEDIN_ENABLED=true
# Provider: 'manual-hubspot' (default) or 'heyreach'
# LINKEDIN_PROVIDER=manual-hubspot
# Daily connection request limit (LinkedIn: ~20/week free, ~100/week Sales Nav)
# LINKEDIN_DAILY_LIMIT=20
#
# If using HeyReach (recommended for automated LinkedIn outreach):
# HeyReach handles connection requests, messages, InMails, follows, profile views.
# You add leads to a campaign via API; HeyReach automates the LinkedIn actions.
# Webhook events close the memory loop (connection accepted, reply received, etc.).
#
# Get API key: HeyReach → Settings → API → copy key
# Test: GET https://api.heyreach.io/api/public/auth/CheckApiKey with X-API-KEY header
# HEYREACH_API_KEY=
#
# Campaign ID: Create a campaign in HeyReach, launch it once, copy the numeric ID.
# Find it: HeyReach → Campaigns → click campaign → ID in URL
# HEYREACH_CAMPAIGN_ID=
#
# Webhooks: In HeyReach dashboard → Integrations → Webhooks, create webhooks
# pointing at your Trigger.dev webhook URLs for these events:
#   CONNECTION_REQUEST_ACCEPTED → heyreach-linkedin-webhook task URL
#   MESSAGE_REPLY_RECEIVED      → heyreach-linkedin-webhook task URL
#   INMAIL_REPLY_RECEIVED       → heyreach-linkedin-webhook task URL
#   CAMPAIGN_COMPLETED          → heyreach-linkedin-webhook task URL
# All events go to the same task URL — the handler routes by event type.

# ─── Phone / Call Outreach (Optional — OFF by default) ────────────
# Set to "true" to enable phone calls for high-score contacts (80+).
# Creates HubSpot CALL tasks with scripts; optionally triggers AI callers.
# CALL_ENABLED=true
# Provider: 'manual-hubspot' (default), 'bland-ai', 'vapi', or 'elevenlabs'
# CALL_PROVIDER=manual-hubspot
# Daily call limit
# CALL_DAILY_LIMIT=20
# Minimum ICP score to trigger a call
# CALL_MIN_SCORE=80
# If using Bland.ai (AI voice calls):
# BLAND_API_KEY=
# BLAND_PHONE_NUMBER_ID=
# If using Vapi (AI voice agents):
# VAPI_API_KEY=
# VAPI_ASSISTANT_ID=
# If using ElevenLabs (Conversational AI + Twilio):
# ELEVENLABS_API_KEY=
# ELEVENLABS_AGENT_ID=
# ELEVENLABS_PHONE_NUMBER_ID=
