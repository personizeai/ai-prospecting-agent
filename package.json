{
  "name": "ai-prospecting-agent",
  "version": "1.0.0",
  "description": "Full end-to-end AI prospecting agent powered by Personize + Trigger.dev",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "setup:schemas": "npx tsx src/setup/create-schemas.ts",
    "setup:governance": "npx tsx src/setup/create-governance.ts",
    "setup": "npm run setup:schemas && npm run setup:governance",
    "gmail:auth": "npx tsx src/setup/gmail-auth.ts",
    "sync:csv": "npx tsx src/scripts/run-csv-sync.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "test:integration": "node --import tsx --test src/__tests__/integration/*.test.ts",
    "test:all": "npm test && npm run test:integration",
    "dev": "npx trigger.dev@latest dev",
    "deploy": "npx trigger.dev@latest deploy"
  },
  "dependencies": {
    "@hubspot/api-client": "^12.0.0",
    "@personize/sdk": "^0.6.6",
    "@trigger.dev/sdk": "^3.0.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.0",
    "googleapis": "^144.0.0",
    "imapflow": "^1.2.16",
    "jsforce": "^3.4.0",
    "nodemailer": "^8.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.11",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
